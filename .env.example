# ─── Supabase ──────────────────────────────────────────────────────────────
# Where to find them:
#   https://supabase.com/dashboard/project/_/settings/api
#   - Project URL          → NEXT_PUBLIC_SUPABASE_URL
#   - anon public key      → NEXT_PUBLIC_SUPABASE_ANON_KEY  (safe to expose)
#   - service_role (secret) → SUPABASE_SERVICE_ROLE_KEY     (NEVER expose)
#
# Required for: persisting purchases/signups, browser-side admin auth,
# invoking the send-emails Edge Function.
#
# Then run supabase/schema.sql in the Supabase SQL editor.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ─── Edge Function: send-emails ─ Supabase Function Secrets ────────────────
# These are NOT read by Next.js — set them as Function Secrets in the
# Supabase Dashboard → Edge Functions → send-emails → Secrets.
#
# Listed here only for reference:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=your-app-password
#   FROM_EMAIL=SeekhoAI <hello@seekhoai.pk>
#   ADMIN_EMAIL=sa5425592@gmail.com

# ─── Meta Pixel (tracking) ─────────────────────────────────────────────────
# Pixel ID from Events Manager → Datasets → SeekhoAI Pixel.
# When set, the snippet auto-loads sitewide via <MetaPixel /> in layout.tsx,
# and the Lead event (free-course signup) + Purchase event (paid checkout)
# fire automatically. Leave empty in dev to avoid polluting analytics.

NEXT_PUBLIC_META_PIXEL_ID=

# ─── Google Analytics (tracking) ───────────────────────────────────────────
# GA4 Measurement ID — looks like G-XXXXXXXXXX.
# Auto-loads sitewide when set. Leave empty in dev.

NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Lead-capture outbound webhook (optional) ──────────────────────────────
# Every free-course signup at /free is POSTed to this URL as JSON:
#   { name, email, phone, source, receivedAt, site, secret? }
#
# Compatible receivers:
#   - Google Sheets Apps Script web app (see scripts/lead-webhook.gs)
#   - Zapier / Make / n8n incoming webhooks
#   - AiSensy / Wati / Interakt WhatsApp Business API providers
#   - Any HTTPS endpoint that accepts JSON
#
# If LEAD_WEBHOOK_URL is unset, the forwarder is silently disabled — the
# signup still succeeds and the lead still lands in Supabase. Failure here
# never blocks the user.
#
# LEAD_WEBHOOK_SECRET is sent both as the X-Webhook-Secret header AND
# embedded in the JSON body as `secret`. Receivers that can read headers
# (most providers) verify the header; receivers that can't (Google Apps
# Script) verify the body field.

LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# ─── Stripe (paid checkout) ────────────────────────────────────────────────
# To enable real payments, set all three Stripe vars below.
#
# Test mode (dev):
#   - STRIPE_SECRET_KEY: Stripe Dashboard → toggle to "Test mode" (top right)
#     → Developers → API keys → reveal "Secret key" (starts with sk_test_).
#     Safe to put in .env.local.
#   - STRIPE_WEBHOOK_SECRET: run the Stripe CLI locally —
#       stripe listen --forward-to localhost:3000/api/stripe/webhook
#     It prints `whsec_...`. Each `stripe listen` session generates a new
#     secret, so update this whenever you restart the CLI. Keep the CLI
#     running while testing payments locally.
#   - STRIPE_PRICE_ID (optional): create a Test-mode Product "Complete AI
#     Bootcamp" at 999 PKR → copy the Price ID. If unset, the API uses
#     inline `price_data` in PKR — both paths work.
#
# Live mode (production):
#   NEVER paste live keys into .env.local or any chat. Set them directly
#   in Vercel → Settings → Environment Variables with the "Production"
#   environment scope:
#     STRIPE_SECRET_KEY=sk_live_...     (server-only)
#     STRIPE_WEBHOOK_SECRET=whsec_...   (from Stripe Dashboard → Developers
#                                        → Webhooks → Add endpoint pointed
#                                        at https://seekhoai.pk/api/stripe/webhook
#                                        → events: checkout.session.completed)
#
# NEXT_PUBLIC_SITE_URL controls the success_url / cancel_url Stripe
# redirects back to after checkout. Set to your live domain in production.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
